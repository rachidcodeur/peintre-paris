# Apache / LiteSpeed uniquement. Avec Nginx, ce fichier est ignoré : voir nginx-site-example.conf

<IfModule mod_headers.c>
  # Images & polices : cache long (fichiers versionnés par nom ou rarement modifiés)
  <FilesMatch "\.(webp|jpe?g|png|gif|svg|ico|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # CSS / JS : 30 jours (ajustez si vous changez souvent sans renommer les fichiers)
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  # HTML : revalidation fréquente pour voir les mises à jour de contenu
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain application/javascript application/json
</IfModule>

# Page d’accueil par défaut
DirectoryIndex index.html
